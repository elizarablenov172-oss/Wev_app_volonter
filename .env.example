# Скопируйте в .env и при необходимости измените значения
DATABASE_URL="postgresql://volonter:volonter@localhost:5433/volonter?schema=public"

# Auth.js (NextAuth v5). Сгенерировать: npx auth secret  (или openssl rand -base64 32)
AUTH_SECRET="change-me"
AUTH_TRUST_HOST=true

# Загрузка файлов (аватары, скриншоты-пруфы)
UPLOAD_DIR="public/uploads"

# Локальный SMTP (MailHog)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Евразия <noreply@evraziya.local>"
